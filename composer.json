{
  "name": "evanschleret/laravel-typebridge",
  "description": "Generate deterministic TypeScript resources from Laravel resource attributes",
  "keywords": [
    "laravel",
    "typescript",
    "resource",
    "json-resource",
    "code-generation",
    "dto",
    "php-attributes",
    "api",
    "types"
  ],
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "illuminate/console": "^12.0 || ^13.0",
    "illuminate/database": "^12.0 || ^13.0",
    "illuminate/filesystem": "^12.0 || ^13.0",
    "illuminate/http": "^12.0 || ^13.0",
    "illuminate/support": "^12.0 || ^13.0"
  },
  "require-dev": {
    "orchestra/testbench": "^10.0 || ^11.0",
    "pestphp/pest": "^3.0 || ^4.0",
    "pestphp/pest-plugin-laravel": "^3.0 || ^4.0"
  },
  "autoload": {
    "psr-4": {
      "EvanSchleret\\LaravelTypeBridge\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "./vendor/bin/pest"
  },
  "extra": {
    "laravel": {
      "providers": [
        "EvanSchleret\\LaravelTypeBridge\\TypeBridgeServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
